{
  "component": "BudgetPulseCard",
  "colors": {
    "card-background-light": "bgElevatedLight",
    "card-background-light-hex": "#FFFFFF",
    "card-background-dark": "bgSecondary",
    "card-background-dark-hex": "#181C27",
    "card-border-light": "borderLight",
    "card-border-light-hex": "#C8C4BC",
    "card-border-dark": "border",
    "card-border-dark-hex": "#2E3453",
    "title-light": "textPrimaryLight",
    "title-dark": "textPrimary",
    "link-color": "brandPrimary",
    "link-color-hex": "#3D5A99",
    "remaining-normal-light": "textPrimaryLight",
    "remaining-normal-dark": "textPrimary",
    "remaining-over-budget-light": "expense",
    "remaining-over-budget-light-hex": "#C0392B",
    "remaining-over-budget-dark": "expenseDark",
    "remaining-over-budget-dark-hex": "#E55A4E",
    "subtext-light": "textSecondaryLight",
    "subtext-dark": "textSecondary",
    "progress-background-light": "bgTertiaryLight",
    "progress-background-dark": "bgTertiary",
    "progress-fill-normal": "brandPrimary",
    "progress-fill-over-budget-light": "expense",
    "progress-fill-over-budget-dark": "expenseDark",
    "today-marker-light": "textSecondaryLight",
    "today-marker-dark": "textTertiary",
    "pace-base-light": "textSecondaryLight",
    "pace-base-dark": "textSecondary",
    "pace-number-light": "textPrimaryLight",
    "pace-number-dark": "textPrimary",
    "safe-amount-ok": "success",
    "safe-amount-ok-hex": "#4CAF50",
    "safe-amount-over-budget-light": "expense",
    "safe-amount-over-budget-dark": "expenseDark",
    "pace-warning": "warning",
    "pace-warning-hex": "#FFA726"
  },
  "spacing": {
    "card-padding": 14,
    "card-padding-note": "Explicit 14dp — no exact AppSpacing token (AppSpacing.md = 12, AppSpacing.lg = 16)",
    "card-horizontal-margin": 16,
    "card-horizontal-margin-token": "AppSpacing.lg",
    "card-bottom-margin": 12,
    "card-bottom-margin-token": "AppSpacing.md",
    "header-to-remaining-gap": 12,
    "header-to-remaining-gap-token": "AppSpacing.md",
    "remaining-to-progress-gap": 10,
    "progress-to-pace-gap": 10,
    "remaining-number-to-subtext-gap": 6,
    "progress-bar-height": 6,
    "today-marker-width": 1.5,
    "today-marker-height": 12,
    "today-marker-vertical-offset": -3
  },
  "typography": {
    "title": "bodyMedium",
    "title-size": 16,
    "title-weight": 500,
    "link": "caption1",
    "link-size": 12,
    "link-weight": 400,
    "remaining-value": "moneyMedium",
    "remaining-size": 20,
    "remaining-weight": 600,
    "remaining-letter-spacing": -0.5,
    "subtext": "caption1",
    "subtext-size": 12,
    "subtext-weight": 400,
    "pace-line": "caption2",
    "pace-line-size": 11,
    "pace-line-weight": 400,
    "pace-number-weight": 500,
    "safe-amount-weight": 600,
    "safe-amount-weight-note": "w600 used (instead of w500) to compensate for green-on-white contrast shortfall"
  },
  "shape": {
    "card-radius": 14,
    "card-radius-token": "AppRadius.lg",
    "card-border-width": 1,
    "progress-bar-radius": 3,
    "progress-bar-height": 6
  },
  "shadow": {
    "light-shadow": "0 2dp 8dp rgba(0,0,0,0.04)",
    "dark-shadow": "none"
  }
}
