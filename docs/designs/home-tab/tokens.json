{
  "scope": "Home Tab — all components",
  "note": "This is the master token reference. Individual component tokens.json files are authoritative per component.",

  "page": {
    "background-light": "bgPrimaryLight",
    "background-light-hex": "#F7F6F3",
    "background-dark": "bgPrimary",
    "background-dark-hex": "#0F1117",
    "horizontal-gutter": 16,
    "horizontal-gutter-token": "AppSpacing.lg"
  },

  "tab-bar": {
    "background-light": "bgSecondaryLight",
    "background-dark": "bgPrimary",
    "active-color": "brandPrimary",
    "inactive-color-light": "textSecondaryLight",
    "inactive-color-dark": "textTertiary",
    "height": 49,
    "height-token": "AppHeights.tabBar"
  },

  "pull-to-refresh": {
    "indicator-color": "brandPrimary"
  },

  "home-header": {
    "ref": "home-header/tokens.json"
  },

  "total-balance-card": {
    "ref": "total-balance-card/tokens.json",
    "gradient-start-light": "brandPrimary",
    "gradient-end-light": "brandPrimaryDim",
    "gradient-start-dark-hex": "#4F46E5",
    "gradient-start-dark-note": "widget-local const — not in AppColors",
    "gradient-end-dark": "brandPrimary"
  },

  "budget-pulse-card": {
    "ref": "budget-pulse-card/tokens.json"
  },

  "insight-card": {
    "ref": "insight-card/tokens.json"
  },

  "recent-transactions": {
    "ref": "recent-transactions/tokens.json"
  },

  "empty-state": {
    "card-1-background-light-hex": "#303D5A99",
    "card-1-background-dark": "brandSurface",
    "card-1-border": "brandPrimary",
    "card-2-3-background-light": "bgElevatedLight",
    "card-2-3-background-dark": "bgSecondary",
    "card-2-3-border-light": "borderLight",
    "card-2-3-border-dark": "border",
    "card-radius": 14,
    "card-radius-token": "AppRadius.lg",
    "card-padding": 16,
    "card-spacing": 8,
    "cta-button-height": 44,
    "cta-button-radius": 10,
    "cta-button-radius-token": "AppRadius.md",
    "cta-button-background": "brandPrimary",
    "cta-button-text": "textOnBrand",
    "section-header-text-light": "textSecondaryLight",
    "section-header-text-dark": "textSecondary",
    "section-header-typography": "caption2"
  },

  "section-headers": {
    "typography": "caption2",
    "transform": "uppercase",
    "color-light": "textSecondaryLight",
    "color-dark": "textSecondary",
    "top-margin": 18,
    "bottom-margin": 10
  },

  "vertical-rhythm": {
    "home-header-bottom": 20,
    "total-balance-card-bottom": 12,
    "budget-pulse-card-bottom": 12,
    "insight-card-bottom": 8,
    "recent-list-bottom": 24
  },

  "new-tokens-required": false,
  "widget-local-constants": [
    {
      "name": "_darkGradientStart",
      "value": "Color(0xFF4F46E5)",
      "file": "total_balance_card.dart",
      "reason": "Dark mode gradient start — approved by Sponsor in epic spec"
    },
    {
      "name": "_warningIconLight",
      "value": "Color(0xFFC2410C)",
      "file": "insight_card.dart",
      "reason": "Warning severity icon stroke — light mode, from reference mockup"
    },
    {
      "name": "_warningIconDark",
      "value": "Color(0xFFFB923C)",
      "file": "insight_card.dart",
      "reason": "Warning severity icon stroke — dark mode, from reference mockup"
    },
    {
      "name": "_warningBgLight",
      "value": "Color(0x26FFA726)",
      "file": "insight_card.dart",
      "reason": "Warning icon background — AppColors.warning at 15% opacity"
    },
    {
      "name": "_warningBgDark",
      "value": "Color(0x33FFA726)",
      "file": "insight_card.dart",
      "reason": "Warning icon background — AppColors.warning at 20% opacity"
    },
    {
      "name": "_infoIconBgLight",
      "value": "Color(0xFFD6DCF0)",
      "file": "insight_card.dart",
      "reason": "Info severity icon background — lightened brand tint"
    },
    {
      "name": "_successIconBgLight",
      "value": "Color(0xFFDCFCE7)",
      "file": "insight_card.dart",
      "reason": "Success severity icon background — green-100"
    },
    {
      "name": "_successIconBgDark",
      "value": "Color(0xFF14532D)",
      "file": "insight_card.dart",
      "reason": "Success severity icon background — dark green"
    },
    {
      "name": "_successIconStrokeLight",
      "value": "Color(0xFF15803D)",
      "file": "insight_card.dart",
      "reason": "Success severity icon stroke — dark green for light mode"
    }
  ]
}
