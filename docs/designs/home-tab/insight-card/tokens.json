{
  "component": "InsightCard",
  "colors": {
    "card-background-light": "bgElevatedLight",
    "card-background-light-hex": "#FFFFFF",
    "card-background-dark": "bgSecondary",
    "card-background-dark-hex": "#181C27",
    "card-border-light": "borderLight",
    "card-border-light-hex": "#C8C4BC",
    "card-border-dark": "border",
    "card-border-dark-hex": "#2E3453",
    "title-light": "textPrimaryLight",
    "title-dark": "textPrimary",
    "subtitle-light": "textSecondaryLight",
    "subtitle-dark": "textSecondary",
    "ink-ripple": "brandPrimaryGlow",
    "ink-ripple-hex": "#303D5A99",

    "warning-icon-bg-light": "rgba(255,167,38,0.15) — no token, use Color(0x26FFA726)",
    "warning-icon-bg-dark": "rgba(255,167,38,0.20) — no token, use Color(0x33FFA726)",
    "warning-icon-stroke-light": "#C2410C — widget-local const _warningIconLight",
    "warning-icon-stroke-dark": "#FB923C — widget-local const _warningIconDark",
    "warning-NEW_TOKEN_REQUIRED": false,

    "info-icon-bg-light": "#D6DCF0 — widget-local const _infoIconBgLight",
    "info-icon-bg-dark": "brandSurface",
    "info-icon-bg-dark-hex": "#1E2E52",
    "info-icon-stroke-light": "brandPrimary",
    "info-icon-stroke-dark": "brandPrimary",
    "info-icon-bg-light-NEW_TOKEN_REQUIRED": false,

    "success-icon-bg-light": "#DCFCE7 — widget-local const _successIconBgLight",
    "success-icon-bg-dark": "#14532D — widget-local const _successIconBgDark",
    "success-icon-stroke-light": "#15803D — widget-local const _successIconStrokeLight",
    "success-icon-stroke-dark": "success",
    "success-icon-stroke-dark-hex": "#4CAF50",
    "success-NEW_TOKEN_REQUIRED": false
  },
  "spacing": {
    "card-padding-vertical": 12,
    "card-padding-horizontal": 14,
    "card-bottom-margin": 8,
    "card-bottom-margin-token": "AppSpacing.sm",
    "card-horizontal-margin": 16,
    "card-horizontal-margin-token": "AppSpacing.lg",
    "icon-to-text-gap": 12,
    "icon-to-text-gap-token": "AppSpacing.md",
    "title-to-subtitle-gap": 2,
    "icon-container-size": 36,
    "icon-size": 18,
    "section-header-top-margin": 18,
    "section-header-bottom-margin": 10
  },
  "typography": {
    "section-header": "caption2",
    "section-header-size": 11,
    "section-header-weight": 400,
    "section-header-transform": "uppercase",
    "title": "bodyMedium",
    "title-size": 16,
    "title-weight": 500,
    "subtitle": "caption1",
    "subtitle-size": 12,
    "subtitle-weight": 400
  },
  "shape": {
    "card-radius": 14,
    "card-radius-token": "AppRadius.lg",
    "card-border-width": 1,
    "icon-container-radius": 10,
    "icon-container-radius-note": "Explicit 10dp — no AppRadius token (AppRadius.md=10 matches — use AppRadius.md)"
  },
  "shadow": {
    "light-shadow": "0 2dp 8dp rgba(0,0,0,0.04)",
    "dark-shadow": "none"
  }
}
